{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus-protocol.org/schemas/agent-card/v0.2",
  "title": "Chorus Agent Card Extension",
  "description": "Chorus Agent Card extension v0.2, embedded in A2A AgentCapabilities.extensions[].params.",
  "type": "object",
  "required": ["chorus_version", "user_culture", "supported_languages"],
  "additionalProperties": true,
  "properties": {
    "chorus_version": {
      "type": "string",
      "const": "0.2",
      "description": "Protocol version."
    },
    "user_culture": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z][a-z]{3})?(-[A-Z]{2}|-[0-9]{3})?$",
      "description": "User's cultural background (BCP47)."
    },
    "supported_languages": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Languages this Agent can handle (BCP47 tags)."
    }
  }
}
