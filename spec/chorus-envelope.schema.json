{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chorus-protocol.org/schemas/envelope/v0.3",
  "title": "Chorus Envelope",
  "description": "Chorus message envelope v0.3, carried as a DataPart in A2A Message.",
  "type": "object",
  "required": ["chorus_version", "original_semantic", "sender_culture"],
  "additionalProperties": true,
  "properties": {
    "chorus_version": {
      "type": "string",
      "enum": ["0.2", "0.3"],
      "description": "Protocol version."
    },
    "original_semantic": {
      "type": "string",
      "minLength": 1,
      "description": "Sender Agent's extracted original semantic intent (natural language)."
    },
    "sender_culture": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z][a-z]{3})?(-[A-Z]{2}|-[0-9]{3})?$",
      "description": "Sender user's cultural background identifier (BCP47)."
    },
    "cultural_context": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Cultural context explanation generated by sender Agent's LLM."
    },
    "intent_type": {
      "type": "string",
      "enum": [
        "greeting", "request", "proposal", "rejection",
        "chitchat", "apology", "gratitude", "information"
      ],
      "description": "Auxiliary intent label."
    },
    "formality": {
      "type": "string",
      "enum": ["formal", "semi-formal", "casual"],
      "description": "Formality level."
    },
    "emotional_tone": {
      "type": "string",
      "enum": ["polite", "neutral", "enthusiastic", "cautious", "apologetic"],
      "description": "Emotional tone."
    },
    "conversation_id": {
      "type": "string",
      "maxLength": 64,
      "description": "Conversation identifier for multi-turn tracking."
    },
    "turn_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Turn number within the conversation."
    }
  }
}
